{
  "manifest_version": 3,
  "name": "Viaduct Install",
  "version": "1.0.0",
  "description": "Install Chrome extensions in Safari via Viaduct",
  "icons": {
    "48": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://chromewebstore.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "nativeMessaging"
  ]
}
