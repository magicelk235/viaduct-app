{
  "name": "chrome2safari",
  "version": "1.0.0",
  "description": "Convert a Chrome extension into a Safari Web Extension (macOS/iOS) ready for local dev or CI/CD.",
  "type": "module",
  "bin": {
    "chrome2safari": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').cpSync('src/templates','dist/templates',{recursive:true})\" && node -e \"require('node:fs').chmodSync('dist/cli.js',0o755)\"",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "chrome-extension",
    "safari",
    "safari-web-extension",
    "web-extension",
    "converter",
    "manifest-v3",
    "macos",
    "xcode",
    "cli"
  ],
  "author": "magicelk235",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magicelk235/Chrome-extensions-to-Safari.git"
  },
  "bugs": {
    "url": "https://github.com/magicelk235/Chrome-extensions-to-Safari/issues"
  },
  "homepage": "https://github.com/magicelk235/Chrome-extensions-to-Safari#readme",
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
